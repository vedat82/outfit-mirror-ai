VITE_APP_ENVIRONMENT=development
# Required for TestFlight/App Store builds. Use a public HTTPS backend URL, not localhost.
VITE_API_BASE_URL=https://api.veerapps.com
VITE_SENTRY_DSN_FRONTEND=
VITE_SENTRY_ENABLE_LOCAL=false
VITE_SENTRY_DEBUG=false
# Local-only Apple IAP debug logs/test helpers. Ignored in production builds.
VITE_IAP_DEBUG=false
# App Store screenshot capture only. Keep false for normal TestFlight/App Store builds.
VITE_APP_STORE_SCREENSHOT_MODE=false
