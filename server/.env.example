PORT=4000
DATABASE_PATH=./data/outfits.db
PUBLIC_API_BASE_URL=https://api.veerapps.com

# iyzico sandbox credentials. Keep these only on the backend.
IYZIPAY_URI=https://sandbox-api.iyzipay.com
IYZIPAY_API_KEY=your_sandbox_api_key
IYZIPAY_SECRET_KEY=your_sandbox_secret_key

# iyzico must call a backend URL after checkout.
# For local sandbox testing, expose the backend with a public HTTPS tunnel and set this.
IYZICO_CALLBACK_URL=https://your-public-backend.example.com/payment/callback

# App URL used after iyzico callback verification.
FRONTEND_URL=http://127.0.0.1:5173

# Launch premium prices in TRY. Billing products will be mapped to these plan ids later.
PREMIUM_MONTHLY_PRICE_TRY=299.00
PREMIUM_YEARLY_PRICE_TRY=1999.00

# OpenAI vision analysis. Keep this only on the backend.
OPENAI_API_KEY=your_openai_api_key
OPENAI_NANO_MODEL=gpt-4.1-nano
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_PRO_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o-mini
# Responses-compatible model that can call the image_generation tool.
OPENAI_IMAGE_MODEL=gpt-4.1
OPENAI_IMAGE_ROUTER_MODEL=gpt-4.1

# Hidden daily AI budgets. Users never see these values.
AI_DAILY_FREE_LIMIT=3
AI_DAILY_TRIAL_LIMIT=45
AI_DAILY_PREMIUM_LIMIT=180

# Premium See On Me daily limits. Use UNLIMITED or SEE_ON_ME_UNLIMITED=true for future unlimited mode.
SEE_ON_ME_TRIAL_DAILY_LIMIT=2
SEE_ON_ME_PREMIUM_DAILY_LIMIT=5
SEE_ON_ME_UNLIMITED=false
SEE_ON_ME_FORCE_DISABLED=false
SEE_ON_ME_OPENAI_TIMEOUT_MS=180000
SEE_ON_ME_COOLDOWN_SECONDS=60
SEE_ON_ME_DAILY_BUDGET_USD=20
SEE_ON_ME_ESTIMATED_COST_USD=0.08
SEE_ON_ME_IP_RATE_LIMIT_WINDOW_MS=3600000
SEE_ON_ME_IP_RATE_LIMIT_MAX_REQUESTS=10
SEE_ON_ME_CACHE_ENABLED=true
SEE_ON_ME_CACHE_TTL_MS=600000
SEE_ON_ME_ADMIN_BYPASS_TOKEN=
SEE_ON_ME_MAX_SINGLE_IMAGE_BYTES=1800000
SEE_ON_ME_MAX_TOTAL_IMAGE_BYTES=6000000
SEE_ON_ME_MAX_REFERENCE_IMAGES=3

# Abuse protection. These are request rate limits, separate from hidden AI usage budgets.
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX_REQUESTS=20
PAYMENT_RATE_LIMIT_WINDOW_MS=600000
PAYMENT_RATE_LIMIT_MAX_REQUESTS=5

# Apple In-App Purchase verification. Required before accepting real Sandbox or
# Production App Store transactions on the backend.
APPLE_BUNDLE_ID=com.vedat.outfitmirrorai
APPLE_APP_APPLE_ID=
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Optional. Defaults to Sandbox outside production and Production in production.
APPLE_IAP_ENVIRONMENT=
# Optional comma-separated paths to Apple root certificates for signed JWS verification.
# If empty, backend still verifies by fetching transaction data from Apple Server API.
APPLE_ROOT_CA_PATHS=
# Keep this true only for local Xcode StoreKit testing outside production.
ALLOW_XCODE_STOREKIT_VERIFICATION=true
ALLOW_PAYMENT_RESET=false

# Sentry monitoring. Keep local dev quiet unless explicitly enabled.
APP_ENVIRONMENT=development
SENTRY_DSN_BACKEND=
SENTRY_ENABLE_LOCAL=false
SENTRY_TEST_ENDPOINT_ENABLED=false
